{
  "title": "HelvarNet",
  "config": {
    "step": {
      "user": {
        "data": {
          "host": "[%key:common::config_flow::data::host%]",
          "port": "[%key:common::config_flow::data::port%]",
          "cluster_id": "Cluster ID (optional)",
          "router_id": "Router ID (optional)"
        },
        "data_description": {
          "cluster_id": "Leave blank to derive from the IP address. Set this only if the router isn't on a standard 10.254.C.R network (for example, reached via a bridge).",
          "router_id": "Leave blank to derive from the IP address. Set this together with Cluster ID."
        }
      }
    },
    "error": {
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]"
    }
  }
}